# =============================================================
# DSCI 551 Demo — Environment Configuration
# =============================================================
# This .env is committed to the repo so the grader can reproduce
# the demo immediately. It contains NO secrets — only local,
# demo-safe defaults. See dsci551/README.md for full setup.
# =============================================================

# -------------------------------------------------------------
# Local PostgreSQL — REQUIRED for all demos
# -------------------------------------------------------------
# Change "xingwei" to your local postgres role if different.
# Run `whoami` on macOS/Homebrew installs. Or just run
# `bash dsci551/setup.sh` which auto-adjusts for you.
DATABASE_URL="postgresql://xingwei@localhost:5432/meowlytics_551"

# -------------------------------------------------------------
# Session / auth — local-only demo value
# -------------------------------------------------------------
AUTH_SECRET="dsci551-local-demo-secret-do-not-use-in-production"
APP_URL="http://localhost:3000"
ADMIN_EMAILS="demo@551.edu"

# -------------------------------------------------------------
# Google Gemini API key
# -------------------------------------------------------------
# Optional for DSCI 551 grading. The database / EXPLAIN ANALYZE
# demonstrations (the actual course deliverables) run without it.
# It is only required to test live AI ingredient analysis from an
# uploaded image. Leave empty to use the pre-seeded data.
GOOGLE_API_KEY=
# -------------------------------------------------------------
# Password-reset emails — not used in the demo
# -------------------------------------------------------------
RESEND_API_KEY=""
EMAIL_FROM="Meowlytics <onboarding@resend.dev>"
