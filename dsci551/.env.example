# DSCI 551 Demo — Environment Template
#
# Copy this file to ".env" in the repository root:
#     cp dsci551/.env.example .env
#
# Then edit DATABASE_URL to match your local PostgreSQL role.
# On macOS Homebrew, the role is usually your shell username.
# Run `whoami` to check.

# -------------------------------------------------------------
# Local PostgreSQL — required for all database demos
# -------------------------------------------------------------
DATABASE_URL="postgresql://xingwei@localhost:5432/meowlytics_551"

# -------------------------------------------------------------
# Auth — any random string is fine for local testing
# -------------------------------------------------------------
AUTH_SECRET="dsci551-local-demo-secret-not-for-production"
APP_URL="http://localhost:3000"
ADMIN_EMAILS="demo@551.edu"

# -------------------------------------------------------------
# Optional: AI ingredient generation
# -------------------------------------------------------------
# The database / EXPLAIN demonstrations do NOT require this key.
# Only set it if you also want to test the live AI analysis feature.
GOOGLE_API_KEY=""

# -------------------------------------------------------------
# Optional: password reset emails
# -------------------------------------------------------------
# Not needed for the demo.
RESEND_API_KEY=""
EMAIL_FROM="Meowlytics <onboarding@resend.dev>"
